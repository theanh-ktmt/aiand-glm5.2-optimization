# Secrets / local settings (WANDB_API_KEY etc.) — never commit
.env

# Benchmark outputs: keep the small aggregated CSVs in git as a backup,
# but not the bulky per-config dirs (*.json, server.log, bench.log, gpu.csv) —
# those go to W&B artifacts instead.
results/*
!results/.gitkeep
!results/*.csv

# Python
__pycache__/
*.pyc
