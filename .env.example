# Copy to .env (which is git-ignored) and fill in. run.sh / run_all.sh auto-load it.
# On the cloud box:  cp .env.example .env  && edit.

# Weights & Biases (results durability). Get a key at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=glm5.2-fp8-opt
# WANDB_ENTITY=your-team        # optional

# Optional overrides
# PORT=8888
# DOWNLOAD_DIR=/workspace/models
# WANDB=0          # set to disable W&B sync
